# Backend Environment Variables
DATABASE_URL=postgresql://ecommerce_user:ecommerce_password@localhost:5432/ecommerce_db
REDIS_URL=redis://localhost:6379

# Frontend Environment Variables (prefix with NEXT_PUBLIC_ for client-side)
NEXT_PUBLIC_API_URL=http://localhost:8000

# GCP Deployment (replace with your values)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_CLUSTER_NAME=nexcart-cluster
